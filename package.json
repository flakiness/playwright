{
  "name": "@flakiness/playwright",
  "version": "1.14.0",
  "packageManager": "pnpm@11.5.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flakiness/playwright.git"
  },
  "exports": {
    ".": {
      "types": "./types/src/playwright-test.d.ts",
      "import": "./lib/playwright-test.js",
      "require": "./lib/playwright-test.js"
    }
  },
  "bin": {
    "flakiness-playwright-shard": "./lib/flakiness-playwright-shard.js"
  },
  "type": "module",
  "description": "A custom Playwright test reporter that generates Flakiness Reports from your Playwright test runs",
  "types": "./types/src/playwright-test.d.ts",
  "scripts": {
    "build": "kubik build.mts",
    "watch": "kubik build.mts -w",
    "test": "playwright test"
  },
  "keywords": [
    "playwright",
    "test",
    "reporter",
    "flakiness",
    "testing",
    "e2e",
    "test-reporting"
  ],
  "author": "Degu Labs, Inc",
  "license": "MIT",
  "engines": {
    "node": "^20.17.0 || >=22.9.0"
  },
  "devDependencies": {
    "@flakiness/flakiness-report": "^0.34.0",
    "@flakiness/playwright": "^1.14.0",
    "@flakiness/sdk": "^3.3.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "esbuild": "^0.27.7",
    "kubik": "^0.24.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
